from fastapi import FastAPI
from fastapi.middleware.cors import CORSMiddleware
from groq import Groq
import datetime
import random

app = FastAPI(title="Friday Assistant - Groq AI")

app.add_middleware(
    CORSMiddleware,
    allow_origins=["*"],
    allow_credentials=True,
    allow_methods=["*"],
    allow_headers=["*"],
)

# YOUR GROQ API KEY
GROQ_API_KEY = "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"

print("=" * 50)
print("🚀 FRIDAY ASSISTANT - Groq AI")
print("=" * 50)

try:
    client = Groq(api_key=GROQ_API_KEY)
    print("✅ Groq API: CONNECTED")
    print("🤖 AI Mode: ENABLED")
except Exception as e:
    client = None
    print(f"❌ Groq API Error: {e}")
    print("🤖 AI Mode: DISABLED")

print("=" * 50)

SYSTEM_PROMPT = """You are F.R.I.D.A.Y., Tony Stark's AI assistant. 
Be helpful, warm, and a little witty. Address user as 'boss'. 
Keep responses very short (1-2 sentences maximum)."""

@app.post("/chat")
async def chat(req: dict):
    user_message = req.get("message", "")
    
    print(f"📨 User: {user_message[:50]}...")
    
    # Quick offline responses
    if "time" in user_message.lower() and len(user_message.split()) < 4:
        now = datetime.datetime.now().strftime("%I:%M %p")
        return {"reply": f"The current time is {now}, boss."}
    
    if "date" in user_message.lower():
        today = datetime.datetime.now().strftime("%B %d, %Y")
        return {"reply": f"Today is {today}, boss."}
    
    # Use Groq AI
    if client:
        try:
            response = client.chat.completions.create(
                model="llama3-70b-8192",
                messages=[
                    {"role": "system", "content": SYSTEM_PROMPT},
                    {"role": "user", "content": user_message}
                ],
                max_tokens=150,
                temperature=0.7
            )
            reply = response.choices[0].message.content
            print(f"✅ AI: {reply[:50]}...")
            return {"reply": reply}
        except Exception as e:
            print(f"❌ Error: {e}")
            return {"reply": f"AI Error: {str(e)[:100]}"}
    
    return {"reply": "Groq API not configured. Please check your API key."}

@app.get("/")
async def root():
    return {"message": "F.R.I.D.A.Y. Assistant API is running!", "status": "online"}

if __name__ == "__main__":
    import uvicorn
    uvicorn.run(app, host="0.0.0.0", port=8000)
